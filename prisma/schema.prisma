// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}



model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String
  passwordHash    String?   // nullable — OAuth users have no password
  role            Role      @default(USER)
  isVerified      Boolean   @default(false)

  // account lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // 2FA
  twoFactorSecret     String?   // TOTP secret (encrypted at rest)
  twoFactorEnabled    Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens RefreshToken[]
  emailTokens   EmailToken[]
  oauthAccounts OAuthAccount[]

  @@map("users")
}

// one row per device/browser session
model RefreshToken {
  id           String   @id @default(uuid())
  token        String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // device tracking
  deviceName   String?  // "Chrome on Windows"
  ipAddress    String?
  userAgent    String?
  lastUsedAt   DateTime @default(now())

  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@map("refresh_tokens")
}

model EmailToken {
  id        String         @id @default(uuid())
  token     String         @unique
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      EmailTokenType
  expiresAt DateTime
  createdAt DateTime       @default(now())

  @@map("email_tokens")
}

// one row per connected OAuth provider per user
model OAuthAccount {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     OAuthProvider
  providerAccountId String   // the id Google/GitHub gives us for this user

  createdAt    DateTime @default(now())

  @@unique([provider, providerAccountId]) // prevent duplicate connections
  @@map("oauth_accounts")
}

enum Role {
  USER
  ADMIN
}

enum EmailTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum OAuthProvider {
  GOOGLE
  GITHUB
}